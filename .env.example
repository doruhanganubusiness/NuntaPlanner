# Supabase — copiază acest fișier în .env.local și completează valorile.
# Le găsești în: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://iwakrrugfdtslficmori.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Doar pe server — NU expune public. Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend) — pentru invitații. Din resend.com → API Keys
RESEND_API_KEY=your-resend-key
# Opțional: expeditor (implicit onboarding@resend.dev, doar cont propriu fără domeniu)
# EMAIL_FROM=NuntaPlanner <onboarding@resend.dev>

# Stripe (Faza 2) — deblocarea plătită a lead-urilor (CPL). Din dashboard.stripe.com
# Cheia secretă (recomandat TEST: sk_test_...). Doar pe server. E TOT ce trebuie —
# plata se confirmă la întoarcerea din Checkout (fără webhook).
STRIPE_SECRET_KEY=sk_test_your-key
# OPȚIONAL: dacă adaugi un webhook Stripe (endpoint /api/v1/stripe/webhook,
# event checkout.session.completed), pune aici signing secret-ul lui.
# STRIPE_WEBHOOK_SECRET=whsec_your-secret

# Blog (WordPress headless) — rădăcina site-ului WordPress (fără /wp-json).
# Cât timp lipsește, paginile de blog există dar sunt goale („în curând").
# WORDPRESS_API_URL=https://blog.nuntaplanner.ro

# Analytics (opțional) — se încarcă DOAR după consimțământ (bannerul de cookies).
# Fără aceste valori, nu se încarcă niciun script Google.
# GTM: Google Tag Manager container (GTM-XXXXXXX)
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# GA4: Google Analytics 4 measurement ID (G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Google Search Console: verificarea se face prin meta tag / DNS, nu prin env.
