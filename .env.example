# Supabase — copiază acest fișier în .env.local și completează valorile.
# Le găsești în: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://iwakrrugfdtslficmori.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Doar pe server — NU expune public. Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend) — pentru invitații. Din resend.com → API Keys
RESEND_API_KEY=your-resend-key
# Opțional: expeditor (implicit onboarding@resend.dev, doar cont propriu fără domeniu)
# EMAIL_FROM=NuntaPlanner <onboarding@resend.dev>

# Stripe (Faza 2) — deblocarea plătită a lead-urilor (CPL). Din dashboard.stripe.com
# Cheia secretă (test: sk_test_...). Doar pe server.
STRIPE_SECRET_KEY=sk_test_your-key
# Semnătura webhook-ului. Din Stripe → Developers → Webhooks (endpoint
# /api/v1/stripe/webhook, event checkout.session.completed) sau din `stripe listen`.
STRIPE_WEBHOOK_SECRET=whsec_your-secret
